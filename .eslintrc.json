{
  "root": true,
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "script" },
  "env": { "node": true, "browser": true, "es2022": true },
  "rules": {
    "indent": ["error", "tab", { "SwitchCase": 1 }],
    "quotes": ["error", "double"],
    "max-len": ["error", 250],
    "curly": "error",
    "no-trailing-spaces": ["error"],
    "no-irregular-whitespace": ["error"]
  }
}
